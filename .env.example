# Saby (SBIS) CRM — п. 50 ТЗ: CRMLead.insertRecord → https://online.sbis.ru/service/
# Включить отправку сделки в CRM:
SBIS_ENABLED=false
# Режим JSON-RPC (рекомендуется по документации «Загрузить сделку»):
SBIS_JSONRPC=true
SBIS_SERVICE_URL=https://online.sbis.ru/service/
# Авторизация JSON-RPC (достаточно одного варианта):
# 1) OAuth-токен приложения:
SBIS_ACCESS_TOKEN=
# 2) Логин/пароль от online.sbis.ru → СБИС.Аутентифицировать (см. help.sbis.ru, раздел «СБИС.Аутентифицировать»):
SBIS_AUTH_URL=https://online.sbis.ru/auth/service/
SBIS_LOGIN=tenditnika
SBIS_PASSWORD=Tenditnik1!
# при нескольких кабинетах на одном логине:
# SBIS_ACCOUNT_NUMBER=
# ID регламента сделки в Saby CRM (целое число)
SBIS_CRM_REGLEMENT_ID=12345
# Опционально: ID ответственного / UUID сотрудника
# SBIS_CRM_RESPONSIBLE=
# Код источника сделки (MrkSourceData.SrcCode)
# SBIS_LEAD_SRC_CODE=
# true/false — UseRules
# SBIS_LEAD_USE_RULES=false
# JSON-массив номенклатуры: [{"code":"X123","price":1500,"count":1}]
# SBIS_LEAD_NOMENCLATURES_JSON=

