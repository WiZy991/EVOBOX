# Шаблон переменных. Скопируйте в `.env.local` (локально) или `.env.production` (сервер `next start`).
# Next.js НЕ читает `.env.example` — только `.env`, `.env.local`, `.env.production` и их `.local` варианты.

NEXT_PUBLIC_SITE_URL=https://evoboxvl.ru
LEAD_RECEIVER_EMAIL=you@example.com

# SMTP почты, с которой сервер отправляет письма (не путать с ящиком получателя).
# Параметры берите в панели почтового хостинга (Beget, Mail.ru, Yandex и т.д.).
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# SBIS / Saby CRM: заявка дублируется в CRM при SBIS_ENABLED=true (формат запроса см. sendSbisLead.ts).
SBIS_ENABLED=false
SBIS_API_URL=
SBIS_API_KEY=
SBIS_SECRET_KEY=
